<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:_1006262.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
        x:Class="_1006262.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Клавиатурный тренажер"
        Width="900" Height="500"
        KeyDown="MainWindow_KeyDown"
        KeyUp="MainWindow_KeyUp">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="10">
        <!-- Статистика и настройки -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20">
                <TextBlock Text="{Binding Errors, StringFormat='Ошибки: {0}'}" 
                          FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Speed, StringFormat='Скорость: {0:F1} зн/с'}" 
                          FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                <TextBlock Text="Длина:" VerticalAlignment="Center"/>
                <Slider Width="150" Minimum="5" Maximum="30" Value="{Binding Length}" 
                       VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Length}" VerticalAlignment="Center" Width="30"/>
                <CheckBox Content="Учитывать регистр" IsChecked="{Binding UseCase}" 
                         VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <Button Content="Start" Command="{Binding StartCommand}" Width="80"/>
            <Button Content="Stop" Command="{Binding StopCommand}" Width="80"/>
        </StackPanel>

        <!-- Отображение целевого текста и ввода -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Padding="15" 
                Margin="0,0,0,10" CornerRadius="8" Background="#F5F5F5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Целевой текст -->
                <TextBlock Grid.Row="0" x:Name="TargetTextBlock" 
                          FontSize="24" FontWeight="Bold" 
                          Margin="0,0,0,10" TextWrapping="Wrap"/>
                
                <!-- Введенный текст -->
                <TextBlock Grid.Row="1" x:Name="InputTextBlock" 
                          FontSize="24" FontWeight="Bold" 
                          Foreground="Blue" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- Виртуальная клавиатура -->
        <Border Grid.Row="3" BorderBrush="LightGray" BorderThickness="1" Padding="10" 
                CornerRadius="5" Background="White">
            <StackPanel Spacing="5" HorizontalAlignment="Center">
                <!-- Row 1: Numbers -->
                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                    <Border x:Name="Key1" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="1" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="Key2" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="2" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="Key3" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="3" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="Key4" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="4" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="Key5" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="5" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="Key6" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="6" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="Key7" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="7" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="Key8" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="8" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="Key9" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="9" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="Key0" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="0" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                </StackPanel>

                <!-- Row 2: QWERTY -->
                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                    <Border x:Name="KeyQ" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="q" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyW" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="w" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyE" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="e" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyR" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="r" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyT" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="t" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyY" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="y" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyU" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="u" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyI" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="i" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyO" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="o" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyP" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="p" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                </StackPanel>

                <!-- Row 3: ASDFG -->
                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                    <Border x:Name="KeyA" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="a" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyS" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="s" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyD" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="d" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyF" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="f" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyG" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="g" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyH" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="h" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyJ" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="j" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyK" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="k" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyL" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="l" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                </StackPanel>

                <!-- Row 4: ZXCVBNM -->
                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                    <Border x:Name="KeyZ" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="z" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyX" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="x" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyC" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="c" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyV" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="v" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyB" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="b" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyN" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="n" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <Border x:Name="KeyM" Width="40" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="m" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                </StackPanel>

                <!-- Row 5: Space and modifiers -->
                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                    <Border x:Name="KeyLeftShift" Width="80" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="Shift" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="12"/>
                    </Border>
                    <Border x:Name="KeySpace" Width="200" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="Space" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="12"/>
                    </Border>
                    <Border x:Name="KeyRightShift" Width="80" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="Shift" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="12"/>
                    </Border>
                    <Border x:Name="KeyCapsLock" Width="70" Height="40" BorderBrush="Gray" 
                           BorderThickness="1" CornerRadius="3" Background="White">
                        <TextBlock Text="Caps" HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" FontSize="12"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>