<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:_040626.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="_040626.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="_040626">

    <DockPanel Margin="15">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
            <Button Content="Создать XML (XmlTextWriter)" Click="OnCreateXmlClick" Padding="15,5"/>
            <Button Content="Читать через XmlDocument" Click="OnReadXmlDocumentClick" Padding="15,5"/>
            <Button Content="Читать через XmlTextReader" Click="OnReadXmlTextReaderClick" Padding="15,5"/>
        </StackPanel>
        <TextBox Name="OutputTextBox" 
                 AcceptsReturn="True" 
                 IsReadOnly="True" 
                 TextWrapping="Wrap"
                 FontFamily="Consolas, Menlo, monospace"
                 Background="#F5F5F5"
                 Watermark="Здесь появится результат работы с XML"/>
    </DockPanel>
</Window>
