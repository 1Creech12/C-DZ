<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="_0406262.Views.MainWindow"
        Title="Размер монитора"
        Width="450" Height="200"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" Spacing="15" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock x:Name="ResultText" 
                   Text="Нажмите кнопку для определения диагонали" 
                   TextWrapping="Wrap" 
                   TextAlignment="Center"
                   FontSize="16"/>
        <Button Content="Определить диагональ" 
                Click="OnGetDiagonalClick"
                Padding="15,8"
                FontSize="14"/>
    </StackPanel>
</Window>